# Copia este archivo como .env y rellena con tus credenciales
# El archivo .env NO se sube a Git

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx

# Resend (modo system en la API). Sin dominio propio verificado, Resend solo entrega bien al email de tu cuenta;
# con el remitente por defecto (onboarding@resend.dev) los demás destinos suelen no recibir el correo.
# 1) Panel Resend → Domains → añade tu dominio y los registros DNS (SPF/DKIM).
# 2) APP_EMAIL_SYSTEM_FROM=Noemi <noreply@TU_DOMINIO_VERIFICADO.com>
RESEND_API_KEY=
# APP_EMAIL_SYSTEM_FROM=Noemi <noreply@tudominio.com>

# OAuth correo Gmail / Microsoft (ver docs/EMAIL-OAUTH-SETUP.md)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8081/auth/email/oauth/google/callback
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:8081/auth/email/oauth/microsoft/callback
